From 7eaf9f89457a4df15123e3c397440aa2974941f5 Mon Sep 17 00:00:00 2001
From: David Steele <david@pgbackrest.org>
Date: Mon, 25 Nov 2024 10:38:37 -0500
Subject: [PATCH 7/9] Update release notes for PostgreSQL 17 support.

Accurately reflect when different versions of PostgreSQL were supported since an update was required for beta3.
---
 doc/resource/git-history.cache  | 6 +++---
 doc/xml/release/2024/2.52.xml   | 4 ++--
 doc/xml/release/2024/2.53.1.xml | 4 ++--
 3 files changed, 7 insertions(+), 7 deletions(-)

diff --git a/doc/resource/git-history.cache b/doc/resource/git-history.cache
index 66c93d02b..d6d07a638 100644
--- a/doc/resource/git-history.cache
+++ b/doc/resource/git-history.cache
@@ -248,7 +248,7 @@
     {
         "commit": "80c9b3001c8f4689837d46783d348a2c839645c0",
         "date": "2024-08-13 11:53:12 +0800",
-        "subject": "PostgreSQL 17beta3 support.",
+        "subject": "PostgreSQL 17 support.",
         "body": "This release changed the control and WAL format, which is very unusual for a beta. Update control and WAL versions/structs to match."
     },
     {
@@ -578,7 +578,7 @@
     {
         "commit": "dfc14b193454b3003c10eb2d021699cbd6294004",
         "date": "2024-05-27 11:13:16 +1000",
-        "subject": "v2.52: PostgreSQL 17 Support"
+        "subject": "v2.52: PostgreSQL 17beta1 Support"
     },
     {
         "commit": "899b8927888f3930f07f5607902d0493bd3b8f05",
@@ -713,7 +713,7 @@
     {
         "commit": "fb22f04555fecfa143354372ec3543ab186c131d",
         "date": "2024-04-18 10:56:24 +1000",
-        "subject": "PostgreSQL 17 support.",
+        "subject": "PostgreSQL 17beta1 support.",
         "body": "Add catalog version and WAL magic for PostgreSQL 17."
     },
     {
diff --git a/doc/xml/release/2024/2.52.xml b/doc/xml/release/2024/2.52.xml
index 96fbabc1e..24862789e 100644
--- a/doc/xml/release/2024/2.52.xml
+++ b/doc/xml/release/2024/2.52.xml
@@ -1,4 +1,4 @@
-<release date="2024-05-27" version="2.52" title="PostgreSQL 17 Support">
+<release date="2024-05-27" version="2.52" title="PostgreSQL 17beta1 Support">
     <release-core-list>
         <text>
             <p><b>NOTE TO PACKAGERS</b>: The build system for <backrest/> is now <proper>meson</proper>. The <proper>autoconf</proper>/<proper>make</proper> build will not receive any new features and will be removed after a few releases.</p>
@@ -37,7 +37,7 @@
                     <release-item-reviewer id="stefan.fercot"/>
                 </release-item-contributor-list>
 
-                <p><proper>PostgreSQL</proper> 17 support.</p>
+                <p><proper>PostgreSQL</proper> 17beta1 support.</p>
             </release-item>
         </release-feature-list>
 
diff --git a/doc/xml/release/2024/2.53.1.xml b/doc/xml/release/2024/2.53.1.xml
index 7ad4162a4..a075b7ad2 100644
--- a/doc/xml/release/2024/2.53.1.xml
+++ b/doc/xml/release/2024/2.53.1.xml
@@ -1,4 +1,4 @@
-<release date="2024-08-19" version="2.53.1" title="PostgreSQL 17beta3 Support">
+<release date="2024-08-19" version="2.53.1" title="PostgreSQL 17 Support">
     <release-core-list>
         <release-bug-list>
             <release-item>
@@ -47,7 +47,7 @@
                     <release-item-contributor id="david.steele"/>
                 </release-item-contributor-list>
 
-                <p><proper>PostgreSQL</proper> 17beta3 support.</p>
+                <p><proper>PostgreSQL</proper> 17 support.</p>
             </release-item>
         </release-improvement-list>
     </release-core-list>
-- 
2.34.1

